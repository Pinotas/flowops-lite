generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EstadoCliente {
  NOVO
  ORCAMENTO
  CONFIRMADO
  CONCLUIDO
}

enum EstadoOrcamento {
  PENDENTE
  ENVIADO
  ACEITE
  REJEITADO
}

enum EstadoTrabalho {
  AGENDADO
  EM_CURSO
  CONCLUIDO
  CANCELADO
}

model Empresa {
  id        String   @id @default(cuid())
  nome      String
  nif       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  utilizadores Utilizador[]
  clientes     Cliente[]
  orcamentos   Orcamento[]
  trabalhos    Trabalho[]
}

model Utilizador {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa   Empresa @relation(fields: [empresaId], references: [id])
  empresaId String

  tokensRecuperacao TokenRecuperacao[]
}

model TokenRecuperacao {
  id        String   @id @default(cuid())
  token     String   @unique
  expiraEm  DateTime
  usado     Boolean  @default(false)
  createdAt DateTime @default(now())

  utilizador   Utilizador @relation(fields: [utilizadorId], references: [id])
  utilizadorId String

  @@index([token])
}

model Cliente {
  id        String        @id @default(cuid())
  nome      String
  telefone  String?
  email     String?
  morada    String?
  estado    EstadoCliente @default(NOVO)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  empresa   Empresa @relation(fields: [empresaId], references: [id])
  empresaId String

  orcamentos Orcamento[]
  trabalhos  Trabalho[]

  @@index([empresaId])
}

model Orcamento {
  id        String          @id @default(cuid())
  descricao String
  preco     Float
  estado    EstadoOrcamento @default(PENDENTE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  cliente   Cliente @relation(fields: [clienteId], references: [id])
  clienteId String

  empresa   Empresa @relation(fields: [empresaId], references: [id])
  empresaId String

  @@index([empresaId])
}

model Trabalho {
  id        String         @id @default(cuid())
  data      DateTime
  notas     String?
  estado    EstadoTrabalho @default(AGENDADO)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  cliente   Cliente @relation(fields: [clienteId], references: [id])
  clienteId String

  empresa   Empresa @relation(fields: [empresaId], references: [id])
  empresaId String

  @@index([empresaId])
}